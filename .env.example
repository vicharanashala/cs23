# ============================================
# FAQ Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# --- Server ---
PORT=3001
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/faq_platform
JWT_SECRET=<your-jwt-secret-min-32-chars>
JWT_EXPIRES_IN=7d

# --- Public Web App ---
VITE_API_BASE_URL=http://localhost:3001/api

# --- Admin Portal ---
VITE_ADMIN_API_BASE_URL=http://localhost:3001/api